
  "info": {
    "name": "Vizsgaremek Cinema Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Alap Postman collection automatikus tesztekkel a Vizsgaremek Cinema Backend API-hoz."
  },
  "item": [
    {
      "name": "Health / Public",
      "item": [
        {
          "name": "List movies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cinema/public/list/movies",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cinema",
                "public",
                "list",
                "movies"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
